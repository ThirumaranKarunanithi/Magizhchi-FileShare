<?xml version="1.0" encoding="utf-8"?>
<!--
  Storage Usage popup — mirrors the web StorageModal. Three tabs at the top
  switch between Overview (per-section breakdown), Groups (per-group rows)
  and Top Files (largest uploads). Filled programmatically by
  StorageUsageDialog from a StorageUsageResponse.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_storage_dialog"
    android:padding="20dp">

    <!-- Header row: title + close × -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Storage Usage"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvPlanLine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Free plan · 5 GB total"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_close_circle"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@android:color/white"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:contentDescription="Close"/>
    </LinearLayout>

    <!-- Hero used / limit panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_storage_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvUsed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvOfTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="of 5.00 GB"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/pbHero"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="6dp"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="#33FFFFFF"
            android:progressTint="@android:color/white"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPercent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0% used"
                android:textColor="#86EFAC"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvFree"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5.00 GB free"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabOverview"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:text="Overview"
            android:textColor="@color/primaryMid"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_chip_active"/>

        <TextView
            android:id="@+id/tabGroups"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:text="Groups"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@android:color/transparent"/>

        <TextView
            android:id="@+id/tabTopFiles"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="Top Files"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@android:color/transparent"/>
    </LinearLayout>

    <!-- Tab body — populated programmatically. Bound height with max so the
         dialog never overflows on small screens. -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:fillViewport="true"
        android:maxHeight="320dp">

        <LinearLayout
            android:id="@+id/tabBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="Includes all uploads regardless of where they were shared"
        android:textColor="#99FFFFFF"
        android:textSize="11sp"
        android:textStyle="italic"/>
</LinearLayout>
