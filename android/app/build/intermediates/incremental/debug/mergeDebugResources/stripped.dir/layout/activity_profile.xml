<?xml version="1.0" encoding="utf-8"?>
<!--
  Profile activity — port of the web ProfileModal. Big avatar at top,
  display name, status message, contact rows (email + mobile) and Logout
  button. Same dotted blue gradient background as the chat screen.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profileRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:titleTextColor="@android:color/white"
            app:navigationIconTint="@android:color/white"
            app:title="My Profile" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="20dp"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- Avatar + name card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="24dp"
                    android:background="@drawable/bg_card_dark">

                    <!-- Avatar — tap to change. The camera badge sits over
                         the lower-right corner like the web ProfileModal. -->
                    <FrameLayout
                        android:id="@+id/avatarFrame"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/profileAvatar"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:visibility="gone"
                            android:contentDescription="Profile photo" />

                        <TextView
                            android:id="@+id/profileInitials"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:background="@drawable/bg_avatar_glass"
                            android:gravity="center"
                            android:textColor="@android:color/white"
                            android:textSize="36sp"
                            android:textStyle="bold" />

                        <!-- Camera affordance — the user can tap anywhere on
                             the avatar to swap the photo, but this badge
                             makes the hit target discoverable. -->
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="bottom|end"
                            android:background="@drawable/bg_avatar_glass"
                            android:gravity="center"
                            android:text="📷"
                            android:textSize="18sp" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/profileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:text="—" />

                        <TextView
                            android:id="@+id/btnEditName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:padding="6dp"
                            android:text="✎"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/statusRow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/profileStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:textStyle="italic"
                            android:gravity="center"
                            android:text="Tap to add a status…" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="✎"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Contact info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_card_dark">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📧 Email"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:id="@+id/profileEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:text="—" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="14dp"
                        android:background="#33FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 Mobile"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:id="@+id/profileMobile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:text="—" />
                </LinearLayout>

                <!-- Storage card -->
                <LinearLayout
                    android:id="@+id/profileStorageCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_card_dark"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💾 Storage usage"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:id="@+id/profileStorageUsed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:text="—" />
                    <ProgressBar
                        android:id="@+id/profileStorageBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@android:color/white"
                        android:progressBackgroundTint="#33FFFFFF" />
                </LinearLayout>

                <!-- Logout button -->
                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="#EF4444"
                    android:text="🚪 Sign out"
                    android:textColor="@android:color/white"
                    android:textStyle="bold" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
