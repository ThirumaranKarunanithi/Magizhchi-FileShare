<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/registerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minHeight="600dp"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Auth card — painted programmatically with the dotted blue
                 gradient (rounded 28dp corners). -->
            <LinearLayout
                android:id="@+id/registerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Back arrow -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_media_previous"
                    android:tint="@android:color/white"
                    android:contentDescription="Back" />

                <!-- Glass logo banner — same as the login screen so the brand
                     identity is consistent across both auth surfaces. -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_logo_glass">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/logo"
                        android:contentDescription="Magizhchi Share" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:text="Create Account"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:text="Join Magizhchi Share for free"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />

                <!-- Plain label + glass EditText (no TextInputLayout). The
                     OutlinedBox style was drawing its own border on top of
                     our custom glass background and the floating-hint cut-out
                     was misaligning. A separate TextView label is cleaner. -->

                <!-- Display Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Full name"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />
                <EditText
                    android:id="@+id/etDisplayName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="Your full name"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#99FFFFFF"
                    android:textSize="14sp" />

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Email address"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="you@example.com"
                    android:inputType="textEmailAddress"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#99FFFFFF"
                    android:textSize="14sp" />

                <!-- Mobile Number -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Mobile number"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />
                <EditText
                    android:id="@+id/etMobile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="+91XXXXXXXXXX"
                    android:inputType="phone"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#99FFFFFF"
                    android:textSize="14sp" />

                <!-- OTP Channel label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Send OTP verification code via"
                    android:textColor="@color/textSecondary"
                    android:textSize="13sp" />

                <!-- OTP Channel selector -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Email channel button -->
                    <Button
                        android:id="@+id/btnEmailChannel"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="📧 Email"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="@android:color/white"
                        android:textColor="@color/primaryMid"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <!-- SMS channel button -->
                    <Button
                        android:id="@+id/btnSmsChannel"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="📱 SMS"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/colorGlassWhite"
                        android:textColor="@color/textSecondary"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                </LinearLayout>

                <!-- Error text -->
                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="#33FF4444"
                    android:padding="10dp"
                    android:textColor="#FFDDDD"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- Send OTP button -->
                <Button
                    android:id="@+id/btnSendOtp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="@android:color/white"
                    android:text="@string/btn_send_otp"
                    android:textColor="@color/primaryMid"
                    android:textStyle="bold" />

                <!-- Progress -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    android:indeterminateTint="@android:color/white" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:background="#33FFFFFF" />

                <!-- Sign-in link -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already have an account?  "
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvSignIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign in"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="?attr/selectableItemBackground"
                        android:paddingStart="2dp"
                        android:paddingEnd="2dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
