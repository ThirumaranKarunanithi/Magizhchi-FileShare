<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Avatar — tappable to open the full-screen photo viewer. -->
    <FrameLayout
        android:id="@+id/avatarFrame"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="gone"
            android:contentDescription="Avatar" />

        <TextView
            android:id="@+id/tvInitials"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_card_direct"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Name + role badge -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRoleBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/bg_pill_inactive"
            android:textColor="@android:color/white"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnMakeAdmin"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:backgroundTint="#CC1565C0"
            android:text="Make Admin"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnRemoveAdmin"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="4dp"
            android:backgroundTint="#CC880E4F"
            android:text="Remove Admin"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnRemove"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="4dp"
            android:backgroundTint="#CC880E4F"
            android:text="Remove"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
