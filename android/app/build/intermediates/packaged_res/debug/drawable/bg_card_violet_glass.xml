<?xml version="1.0" encoding="utf-8"?>
<!--
  Violet-tinted glass card. Used by SharedFilesActivity rows and the stats
  banner so received-share entries have the same purple-accent identity
  as the web "Shared in this space" section.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#4D6A1B9A" />

    <stroke
        android:width="1dp"
        android:color="#80C4B5FD" />

    <corners android:radius="16dp" />

</shape>
