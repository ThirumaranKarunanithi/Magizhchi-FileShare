<?xml version="1.0" encoding="utf-8"?>
<!--
  Glass container behind the auth-screen logo. Translucent white fill +
  white-glass border + 20dp pill corners. Shows on top of the dotted blue
  card; the logo image sits centered inside.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#33FFFFFF" />

    <stroke
        android:width="1dp"
        android:color="#80FFFFFF" />

    <corners android:radius="24dp" />

</shape>
