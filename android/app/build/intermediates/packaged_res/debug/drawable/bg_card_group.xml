<?xml version="1.0" encoding="utf-8"?>
<!--
  GROUP conversation card — pink glass matching the web sidebar.
  Web uses rgba(219,39,119,0.32) (pink-600 at ~32%) with a soft white border.
  Android: solid pink with translucent fill + a light pink-100 hairline.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#52DB2777" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#80F9A8D4" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
