<?xml version="1.0" encoding="utf-8"?>
<!--
  Auth-page input field background.
  Mirrors the web .input-field style: white-80 fill on top of the gradient
  background, slate-300 hairline border, 12dp corners. Pair with
  android:textColor="@color/inputText" so the dark text stays readable.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="@color/inputFill" />

    <stroke
        android:width="1dp"
        android:color="@color/inputStroke" />

    <corners android:radius="12dp" />

</shape>
