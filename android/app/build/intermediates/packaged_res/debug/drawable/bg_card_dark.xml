<?xml version="1.0" encoding="utf-8"?>
<!--
  Darker card variant used by the chat-screen file / folder rows. A slate-900
  fill at ~38% alpha sits on top of the sky-blue gradient, giving the rows
  enough contrast to read as their own surface.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#600F172A" />

    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />

    <corners android:radius="16dp" />

</shape>
