<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootHome"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="44dp">

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <!-- Circular Avatar -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp">

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:visibility="gone"
                    android:contentDescription="Avatar" />

                <TextView
                    android:id="@+id/tvAvatarInitials"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_avatar_glass"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Welcome text (two lines) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back 👋"
                    android:textColor="#475569"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading…"
                    android:textColor="#0F172A"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Bell + unread-count badge stacked in a FrameLayout -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp">

                <ImageButton
                    android:id="@+id/btnBell"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input"
                    android:src="@drawable/ic_bell"
                    android:scaleType="centerInside"
                    android:padding="10dp"
                    android:tint="@color/primaryMid"
                    android:contentDescription="Notifications" />

                <!-- Red unread-count badge — toggled visible from MainActivity -->
                <TextView
                    android:id="@+id/tvBellBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-2dp"
                    android:layout_marginEnd="-2dp"
                    android:background="@drawable/bg_bell_badge"
                    android:gravity="center"
                    android:minWidth="18dp"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:ignore="SpUsage"
                    xmlns:tools="http://schemas.android.com/tools" />
            </FrameLayout>

        </LinearLayout>

        <!-- ── Storage + Shared cards (equal size, both clickable) ─────────
             measureWithLargestChild=true + matching weight=1 forces the cards
             to share the row's tallest cell exactly. Fixed height so both are
             literally the same size regardless of internal content. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:measureWithLargestChild="true"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <!-- My Storage -->
            <LinearLayout
                android:id="@+id/cardStorage"
                android:layout_width="0dp"
                android:layout_height="108dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_storage"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☁️ My Storage"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStorageUsed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Loading…"
                    android:textColor="#CCffffff"
                    android:textSize="11sp" />

                <!-- Pushes the progress bar to the bottom so both cards' bottom rows align -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- Glass-styled progress wrapper. Tapping it opens the
                     Storage Usage breakdown popup (the same one the web
                     sidebar's storage-progress click opens). -->
                <FrameLayout
                    android:id="@+id/storageProgressContainer"
                    android:layout_width="match_parent"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_glass_progress"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="2dp">

                    <ProgressBar
                        android:id="@+id/storageProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="@android:color/transparent"
                        android:progressTint="@android:color/white" />
                </FrameLayout>
            </LinearLayout>

            <!-- Shared Files — identical shape + height as My Storage. -->
            <LinearLayout
                android:id="@+id/cardShared"
                android:layout_width="0dp"
                android:layout_height="108dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_shared"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔗 Shared Files"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSharedSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Loading…"
                    android:textColor="#CCffffff"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Search bar ───────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="6dp">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawableTint="#94A3B8"
                android:drawablePadding="8dp"
                android:hint="@string/hint_search"
                android:inputType="text"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/inputText"
                android:textColorHint="@color/inputHint"
                android:textSize="14sp" />

            <!-- People / Groups pill toggles -->
            <LinearLayout
                android:id="@+id/tabsRow"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:orientation="horizontal"
                android:padding="3dp">

                <TextView
                    android:id="@+id/chipPeople"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_chip_active"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="👤 People"
                    android:textColor="@color/primaryMid"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipGroups"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="👥 Groups"
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── Conversations list ───────────────────────────────────────── -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="@color/primaryMid"
            android:visibility="gone" />

        <!-- Friend-search section. Hidden by default; revealed when the
             search query is ≥ 2 chars. Mirrors the web sidebar's "People"
             section so users can find friends who aren't yet a connection.
             Section itself has no horizontal padding so the result rows can
             render edge-to-edge; the header / empty / progress pieces add
             their own padding so they're not flush with the screen edge. -->
        <LinearLayout
            android:id="@+id/friendSearchSection"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvFriendSearchHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp"
                android:text="👤 People"
                android:textColor="#475569"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tvFriendSearchEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="No people match your search."
                android:textColor="#64748B"
                android:textSize="13sp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/friendSearchProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:indeterminateTint="@color/primaryMid"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerFriendSearch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="80dp" />
        </LinearLayout>

        <!-- Edge-to-edge conversation list. Side padding is intentionally 0
             so the row backgrounds extend to the screen edge; rows handle
             their own internal padding. -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerConversations"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="New Group"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@android:color/white"
        app:tint="@color/primaryMid" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
