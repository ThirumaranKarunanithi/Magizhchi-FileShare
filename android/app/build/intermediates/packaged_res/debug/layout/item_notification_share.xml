<?xml version="1.0" encoding="utf-8"?>
<!-- A single shared-with-me file row for NotificationsActivity. Mirrors the
     web SharedFiles row: file emoji, file name, sender + size + date,
     "Open chat" hint via tap. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_card_dark"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvIcon"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:gravity="center"
        android:textSize="22sp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/bg_avatar_glass" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textColor="#99FFFFFF"
        android:textSize="22sp"
        android:layout_marginStart="6dp" />
</LinearLayout>
