<?xml version="1.0" encoding="utf-8"?>
<!--
  Full-screen avatar viewer. Black backdrop, centred image, name overlay
  at the top, tap-anywhere-to-dismiss. Used whenever the user taps a
  profile picture in the home conversation list, the friend-search results,
  the chat toolbar, or the group-info member list.

  Falls back to a large initials block when the user has no photo set, so
  every avatar is tappable regardless of whether a real photo exists.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/avatarRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#000000"
    android:clickable="true"
    android:focusable="true">

    <!-- Photo. fitCenter keeps the original aspect ratio while filling
         as much of the screen as possible. -->
    <ImageView
        android:id="@+id/avatarImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:contentDescription="Profile photo" />

    <!-- Initials fallback — shown when no photo is set. Sized big enough
         to feel like an "enlarged" view of the small avatar in the list. -->
    <TextView
        android:id="@+id/avatarInitials"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_avatar_glass"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textSize="80sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Top bar with name + close button. Sits on top of the image with
         a subtle gradient so text stays readable. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#88000000">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@android:color/white"
            android:contentDescription="Close" />
    </LinearLayout>

</FrameLayout>
