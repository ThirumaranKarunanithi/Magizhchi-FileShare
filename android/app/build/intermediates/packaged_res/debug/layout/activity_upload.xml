<?xml version="1.0" encoding="utf-8"?>
<!--
  Full-screen upload composer — mirrors the web upload modal.
  Shows the file count, caption, download-permission picker (3 pills),
  Cancel + Upload buttons, and a progress strip across the top while files
  upload sequentially.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/uploadRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:titleTextColor="@android:color/white"
            app:navigationIconTint="@android:color/white"
            app:title="Upload Files" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- File summary card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:background="@drawable/bg_card_dark">

                    <TextView
                        android:id="@+id/tvFileCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:text="0 files selected" />

                    <TextView
                        android:id="@+id/tvDestination"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp"
                        android:text="—" />

                    <LinearLayout
                        android:id="@+id/fileList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />
                </LinearLayout>

                <!-- Caption -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Description (optional)"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <EditText
                    android:id="@+id/etCaption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="Add a note about these files…"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLength="500"
                    android:minLines="2"
                    android:padding="12dp"
                    android:textColor="@color/inputText"
                    android:textColorHint="@color/inputHint"
                    android:gravity="top|start" />

                <!-- Download permission -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Download Permission"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/permAnyone"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_perm_pill_active">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⬇"
                            android:textSize="18sp"
                            android:textColor="#0284C7" />
                        <TextView
                            android:id="@+id/permAnyoneLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Anyone"
                            android:textColor="#0284C7"
                            android:textStyle="bold"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/permAnyoneDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Can download"
                            android:textColor="#0284C7"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/permViewOnly"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_perm_pill_inactive">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👁"
                            android:textSize="18sp"
                            android:textColor="@android:color/white" />
                        <TextView
                            android:id="@+id/permViewOnlyLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View only"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/permViewOnlyDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Preview only"
                            android:textColor="#CCFFFFFF"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/permAdmins"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_perm_pill_inactive">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛡"
                            android:textSize="18sp"
                            android:textColor="@android:color/white" />
                        <TextView
                            android:id="@+id/permAdminsLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Admins"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/permAdminsDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Group admins only"
                            android:textColor="#CCFFFFFF"
                            android:textSize="9sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPermHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Anyone with access can preview and download."
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"
                    android:textStyle="italic" />
            </LinearLayout>
        </ScrollView>

        <!-- Progress (shown during upload) -->
        <ProgressBar
            android:id="@+id/uploadProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone"
            android:progressTint="@android:color/white"
            android:progressBackgroundTint="#33FFFFFF" />

        <!-- Footer buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/colorGlassWhite"
                android:text="Cancel"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btnUpload"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:backgroundTint="@android:color/white"
                android:text="⬆ Upload"
                android:textColor="@color/primaryMid"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
