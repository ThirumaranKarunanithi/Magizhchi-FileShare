<?xml version="1.0" encoding="utf-8"?>
<!--
  Notifications screen — Android port of the web notification surface.
  The web UI shows toasts + a connection-requests modal; here we combine
  both into a single scrollable activity with two sections:
    1. Pending connection requests (with Accept/Reject)
    2. Recent files / folders shared with me
  Background uses the same dotted-blue gradient as Chat / Profile, painted
  programmatically on the root.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/notifRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:fitsSystemWindows="true">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:titleTextColor="@android:color/white"
            app:navigationIconTint="@android:color/white"
            app:title="🔔 Notifications" />

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Section 1 — Connection requests -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤝 Connection requests"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/requestsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/emptyRequests"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No pending requests."
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"
                        android:textStyle="italic"
                        android:padding="16dp"
                        android:gravity="center"
                        android:background="@drawable/bg_card_dark" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="22dp"
                        android:layout_marginBottom="14dp"
                        android:background="#33FFFFFF" />

                    <!-- Section 2 — Recent shares -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📥 Recent shares"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/sharesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/emptyShares"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nothing has been shared with you recently."
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"
                        android:textStyle="italic"
                        android:padding="16dp"
                        android:gravity="center"
                        android:background="@drawable/bg_card_dark" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="20dp"
                        android:indeterminateTint="@android:color/white"
                        android:visibility="gone" />
                </LinearLayout>
            </ScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
