<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom title view inserted into the chat-screen Toolbar.
  Layout: avatar circle on the left + two stacked TextViews (name on top,
  status message on the bottom). Mirrors the web ChatWindow header.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <FrameLayout
        android:id="@+id/toolbarAvatarBox"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="10dp">

        <ImageView
            android:id="@+id/toolbarAvatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="Conversation avatar" />

        <TextView
            android:id="@+id/toolbarAvatarInitials"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar_glass"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/toolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/toolbarStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
