<?xml version="1.0" encoding="utf-8"?>
<!-- The CoordinatorLayout root takes the entire window so the dotted gradient
     can extend behind the status bar. The inner LinearLayout uses
     fitsSystemWindows="true" to absorb the top inset and push the toolbar
     below the status bar — that's what fixes the "header hidden behind the
     notification bar" bug. -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:fitsSystemWindows="true">

        <!-- Toolbar — uses a custom title view (avatar + name + status). The
             popupTheme keeps the overflow / popup menu DARK so it matches
             the gradient background instead of flashing a white menu sheet. -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:contentInsetStartWithNavigation="0dp"
            app:titleTextColor="@android:color/white"
            app:subtitleTextColor="@color/textSecondary"
            app:navigationIconTint="@android:color/white"
            app:popupTheme="@style/Theme.MagizhchiShare.PopupDark">

            <include
                android:id="@+id/toolbarTitleView"
                layout="@layout/view_chat_toolbar_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </androidx.appcompat.widget.Toolbar>

        <!-- Breadcrumb strip — shown when the user is INSIDE a folder.
             Tapping "🏠 All Files" pops back to the conversation root; tapping
             any intermediate segment jumps to that level. -->
        <HorizontalScrollView
            android:id="@+id/breadcrumbScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:visibility="gone"
            android:background="#22FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <LinearLayout
                android:id="@+id/breadcrumb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <!-- Search + single Filter button (replaces the multi-chip strip).
             Equal top + bottom padding so the field sits centered between
             the breadcrumb above and the list below. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_search_files"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textSecondary" />

            <Button
                android:id="@+id/btnFilter"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/colorGlassWhite"
                android:text="🎯 All"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <!-- View-mode picker — Large / Medium / Details. Mirrors the
                 web ChatWindow's top-right view-mode toolbar but compresses
                 the six modes into the three the user requested. -->
            <Button
                android:id="@+id/btnViewMode"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:backgroundTint="@color/colorGlassWhite"
                android:text="≡"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:contentDescription="View mode" />
        </LinearLayout>

        <!-- Selection toolbar — visible only when adapter is in selection mode -->
        <LinearLayout
            android:id="@+id/selectionToolbar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone"
            android:background="#1AFFFFFF">

            <TextView
                android:id="@+id/tvSelectionCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="0 selected" />

            <ImageButton
                android:id="@+id/btnSelectAll"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/checkbox_on_background"
                android:tint="@android:color/white"
                android:contentDescription="Select all" />

            <ImageButton
                android:id="@+id/btnDeleteSelected"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="#EF4444"
                android:contentDescription="Delete selected" />

            <ImageButton
                android:id="@+id/btnExitSelection"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@android:color/white"
                android:contentDescription="Exit selection" />
        </LinearLayout>

        <!-- Load More (at top of list, pages older messages) -->
        <Button
            android:id="@+id/btnLoadMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:backgroundTint="@color/colorGlassWhite"
            android:text="@string/btn_load_more"
            android:textColor="@android:color/white"
            android:visibility="gone" />

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="@android:color/white"
            android:visibility="gone" />

        <!-- Files list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerFiles"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="80dp" />

    </LinearLayout>

    <!-- Upload FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabUpload"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Upload file"
        android:src="@android:drawable/ic_menu_upload"
        app:backgroundTint="@color/primaryMid"
        app:tint="@android:color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
