<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MagizhchiShare" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primaryMid</item>
        <item name="colorPrimaryVariant">@color/primaryDark</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/primaryLight</item>
        <item name="colorSecondaryVariant">@color/primaryMid</item>
        <item name="colorOnSecondary">@android:color/white</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/primaryDark</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/primaryDark</item>

        <!-- Typography -->
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>

    </style>

    <!-- Dark sheet for any PopupMenu / Toolbar overflow. Used by the chat
         screen's overflow menu so the menu items (Manage Group, Exit, etc.)
         appear on a dark slate background that matches the chat gradient. -->
    <style name="Theme.MagizhchiShare.PopupDark" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:colorBackground">#0F172A</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">#CCFFFFFF</item>
    </style>

    <!-- Theme for AvatarViewerActivity. Black background, no action bar so
         the layout's own custom top bar takes over the screen. Inherits
         from the app theme so colors / typography stay consistent. -->
    <style name="Theme.MagizhchiShare.AvatarViewer" parent="Theme.MagizhchiShare">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

</resources>
